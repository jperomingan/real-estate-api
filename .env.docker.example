# Docker environment example
# Copy this file to .env.docker and change values as needed.

NODE_ENV=production
PORT=4000
APP_URL=http://localhost:4000
ALLOWED_ORIGINS=http://localhost:4000,http://localhost:3000,http://localhost:5173

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=real_estate_db
POSTGRES_PORT=5433

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/real_estate_db?schema=public

# Must be at least 32 characters.
JWT_SECRET=replace_with_a_random_secret_at_least_32_characters
